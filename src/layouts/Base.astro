---
import '../styles/fonts.css';
import '../styles/global.css';
import '../styles/motion.css';

interface Props {
  title?: string;
  description?: string;
  /** Reader route drives its own scrolling — skip Lenis + progress hairline. */
  chromeless?: boolean;
}

const {
  title = 'Pressroom — Asu Azure',
  description = 'Doujinshi library & reader by Asu Azure.',
  chromeless = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);

// Alias identity only — never the owner's real name (see CLAUDE.md identity separation).
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      name: 'Asu Azure',
      url: Astro.site?.href,
      jobTitle: 'Illustrator',
      sameAs: ['https://x.com/asukonpeki'],
    },
    {
      '@type': 'WebSite',
      name: 'Pressroom — Asu Azure',
      url: Astro.site?.href,
    },
  ],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c0c0d" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Pressroom — Asu Azure" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@asukonpeki" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={jsonLd} />

    {
      import.meta.env.PROD && (
        <script
          is:inline
          set:html={`window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };`}
        />
      )
    }
    {import.meta.env.PROD && <script is:inline defer src="/_vercel/insights/script.js" />}
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%232742f0'/%3E%3Ctext x='32' y='44' font-family='Georgia,serif' font-size='34' font-style='italic' text-anchor='middle' fill='%23f4f1ea'%3EP%3C/text%3E%3C/svg%3E"
    />
    <title>{title}</title>

    <link rel="preload" href="/fonts/StackSansHeadline-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/SpaceGrotesk-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-var.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body data-chromeless={chromeless ? 'true' : null}>
    <div class="grid-bg" aria-hidden="true"></div>
    <div class="grain" aria-hidden="true"></div>
    {!chromeless && <div class="progress-line" aria-hidden="true" />}
    <div class="cursor" aria-hidden="true"><span class="cursor__label mono"></span></div>

    <slot />

    <style>
      .cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--fg);
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        mix-blend-mode: difference;
        transition: width 0.25s var(--ease), height 0.25s var(--ease);
      }
      .cursor.is-hover {
        width: 38px;
        height: 38px;
        background: var(--ink);
      }
      .cursor__label {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 0.5rem;
        letter-spacing: 0.08em;
        color: var(--bg);
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.2s var(--ease);
      }
      .cursor.is-label {
        width: 62px;
        height: 62px;
        background: var(--ink);
        mix-blend-mode: normal;
      }
      .cursor.is-label .cursor__label { opacity: 1; }
      @media (pointer: coarse) {
        .cursor { display: none; }
      }
    </style>

    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Mobile browsers fire resize when the URL bar collapses; recomputing every
      // trigger there made start positions jump around mid-scroll.
      ScrollTrigger.config({ ignoreMobileResize: true });

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const finePointer = window.matchMedia('(pointer: fine)').matches;
      const chromeless = document.body.dataset.chromeless === 'true';

      // --- Smooth inertia scroll (the "premium feel") ---
      // The reader route owns its own scrolling (flip mode has none; scroll mode
      // mounts Lenis on its own container), so skip the global instance there.
      if (!chromeless) {
        const lenis = new Lenis({
          duration: 1.1,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
        });
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);
        (window as unknown as { __lenis?: Lenis }).__lenis = lenis;

        // --- Scroll-progress hairline (top edge) ---
        const progress = document.querySelector<HTMLElement>('.progress-line');
        if (progress) {
          const setP = gsap.quickTo(progress, 'scaleX', { duration: 0.18, ease: 'none' });
          ScrollTrigger.create({ start: 0, end: 'max', onUpdate: (self) => setP(self.progress) });
        }
      }

      // --- Custom cursor + contextual label + magnetic hover targets ---
      const cursor = document.querySelector<HTMLElement>('.cursor');
      const cursorLabel = cursor?.querySelector<HTMLElement>('.cursor__label');
      if (cursor && finePointer) {
        const xTo = gsap.quickTo(cursor, 'x', { duration: 0.35, ease: 'power3' });
        const yTo = gsap.quickTo(cursor, 'y', { duration: 0.35, ease: 'power3' });
        window.addEventListener('mousemove', (e) => {
          xTo(e.clientX);
          yTo(e.clientY);
        });
        // Islands mount after this runs — event delegation instead of a one-shot
        // querySelectorAll so Svelte-rendered links/buttons get the hover cursor too.
        const hoverSel = 'a, button, [data-hover]';
        document.addEventListener('mouseover', (e) => {
          if ((e.target as Element | null)?.closest?.(hoverSel)) cursor.classList.add('is-hover');
        });
        document.addEventListener('mouseout', (e) => {
          if ((e.target as Element | null)?.closest?.(hoverSel)) cursor.classList.remove('is-hover');
        });
        document.addEventListener('mouseover', (e) => {
          const el = (e.target as Element | null)?.closest?.('[data-cursor]') as HTMLElement | null;
          if (el) {
            if (cursorLabel) cursorLabel.textContent = el.dataset.cursor ?? '';
            cursor.classList.add('is-label');
          } else {
            cursor.classList.remove('is-label');
          }
        });

        // Magnetic hover: elements drift toward the cursor (award-site staple)
        if (!prefersReduced) {
          document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((el) => {
            const mx = gsap.quickTo(el, 'x', { duration: 0.4, ease: 'power3' });
            const my = gsap.quickTo(el, 'y', { duration: 0.4, ease: 'power3' });
            const strength = 0.4;
            el.addEventListener('mousemove', (e) => {
              const r = el.getBoundingClientRect();
              mx((e.clientX - (r.left + r.width / 2)) * strength);
              my((e.clientY - (r.top + r.height / 2)) * strength);
            });
            el.addEventListener('mouseleave', () => {
              mx(0);
              my(0);
            });
          });
        }
      }
    </script>
  </body>
</html>
