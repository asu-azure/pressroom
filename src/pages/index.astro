---
import Base from '../layouts/Base.astro';
import Library from '../components/library/Library.svelte';

export const prerender = true;
---

<Base>
  <main class="spread spread--ink lib-shell">
    <header class="lib-hero">
      <div class="bracket bracket--tl" aria-hidden="true"></div>
      <div class="bracket bracket--tr" aria-hidden="true"></div>
      <p class="mono lib-hero__kicker" id="lib-kicker">ASU AZURE · PRESSROOM</p>
      <h1 class="mega lib-hero__title" data-vel>
        <span class="reveal-mask"><span id="lib-title-line">Press<span class="flow-text">room</span></span></span>
      </h1>
      <p class="serif lib-hero__sub" id="lib-sub">同人誌・校正刷り・欄外の注 — 綴じたままのかたちで。</p>
      <p class="mono lib-hero__devnote" id="lib-devnote">※ 本サイトは開発中です — 校正・確認用の公開です。</p>
      <div class="rgb-line" aria-hidden="true"></div>
    </header>

    <div class="proofbar spread--paper" aria-hidden="true">
      <span class="crop crop--tl"></span>
      <span class="crop crop--tr"></span>
      <span class="crop crop--bl"></span>
      <span class="crop crop--br"></span>
      <span class="regmark proofbar__reg proofbar__reg--l"></span>
      <span class="regmark proofbar__reg proofbar__reg--r"></span>

      <div class="proofbar__row">
        <span class="proofbar__label mono">校正刷り · PROOF SHEET</span>
        <span class="proofbar__cmyk">
          <i style="background:#18c4d6"></i>
          <i style="background:#ff3d8b"></i>
          <i style="background:#e8a31a"></i>
          <i style="background:#16140f"></i>
          <span class="mono proofbar__cmyk-lab">CMYK</span>
        </span>
        <span class="proofbar__meta mono">No.05 · ASU AZURE 印</span>
        <span class="hanko proofbar__seal">校</span>
      </div>
    </div>

    <Library client:only="svelte" />

    <footer class="lib-foot">
      <span class="mono">© ASU AZURE</span>
      <span class="lib-foot__links">
        <a class="mono" href="https://x.com/asukonpeki" data-magnetic>X — @ASUKONPEKI</a>
        <a class="mono lib-foot__studio" href="/studio" data-magnetic>STUDIO ⌘</a>
      </span>
    </footer>
  </main>
</Base>

<script>
  import { gsap } from 'gsap';
  import { decode } from '../scripts/text';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduced) {
    const kicker = document.getElementById('lib-kicker');
    if (kicker) decode(kicker, kicker.textContent ?? '', 950);

    const line = document.getElementById('lib-title-line');
    if (line) {
      gsap.fromTo(
        line,
        { yPercent: 110 },
        { yPercent: 0, duration: 1.0, ease: 'power3.out', delay: 0.12 },
      );
    }
    const sub = document.getElementById('lib-sub');
    if (sub) {
      gsap.fromTo(
        sub,
        { opacity: 0, y: 18 },
        { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', delay: 0.4 },
      );
    }
  }
</script>

<style>
  .lib-shell {
    position: relative;
    z-index: 1;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }
  .lib-hero {
    position: relative;
    padding: clamp(5rem, 14vh, 9rem) var(--pad) clamp(2rem, 5vh, 3.5rem);
  }
  .lib-hero .bracket--tl { top: clamp(2.4rem, 6vh, 4rem); }
  .lib-hero .bracket--tr { top: clamp(2.4rem, 6vh, 4rem); }
  .lib-hero__kicker { margin-bottom: 1.2rem; }
  .lib-hero__title { color: var(--fg); }
  .lib-hero__sub {
    margin-top: 1.4rem;
    max-width: 34em;
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: var(--fg-dim);
  }
  .lib-hero__devnote {
    margin-top: 1.1rem;
    color: #e8a31a;
    font-size: 0.6rem;
  }
  .rgb-line {
    margin-top: clamp(1.6rem, 4vh, 2.6rem);
    height: 2px;
    background: var(--accent);
    position: relative;
  }
  .rgb-line::before, .rgb-line::after { content: ''; position: absolute; inset: 0; mix-blend-mode: screen; }
  .rgb-line::before { background: #18c4d6; animation: rgb-jit 3.2s ease-in-out infinite; }
  .rgb-line::after  { background: #ff3d8b; animation: rgb-jit 3.2s ease-in-out infinite reverse; }
  .proofbar {
    margin-bottom: clamp(2rem, 5vh, 3.5rem);
  }
  .lib-foot {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(2rem, 5vh, 3rem) var(--pad);
    border-top: 1px solid var(--line);
  }
  .lib-foot a:hover { color: var(--accent); }
  .lib-foot__links { display: flex; gap: 1.6rem; }
  .lib-foot__studio { color: var(--fg-faint); }
</style>
