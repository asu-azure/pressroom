---
import Base from '../../layouts/Base.astro';
import Reader from '../../components/reader/Reader.svelte';

// Server-output shell: the slug is only passed into the island; all data is
// fetched client-side with the anon key (public read via RLS).
const { slug } = Astro.params;
---

<Base title={`Reading — Pressroom`} chromeless>
  <Reader client:only="svelte" slug={slug!} />
</Base>
